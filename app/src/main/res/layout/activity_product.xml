<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Search Bar -->
        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:background="#F2F2F2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="16dp">

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search"
                android:background="@null"
                android:paddingStart="8dp"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/ivCart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/cart"
                android:layout_marginStart="8dp"
                android:padding="4dp" />
        </LinearLayout>

        <!--  Product Image -->
        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="0dp"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:src="@drawable/oil"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/searchBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/rounded_orange_bg" />

        <LinearLayout
            android:id="@+id/tagContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/ivProduct"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="official store"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/rounded_orange_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="free delivery"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/rounded_blue_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />
        </LinearLayout>


        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            android:text="Discusses The Factors That Make A Logo Successful By Analyzing The Research, Brainstorming, Sketching, And Stylistic Experiments That Led To Its Development."
            android:textColor="#555555"
            android:textSize="14sp"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toBottomOf="@id/tagContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <LinearLayout
            android:id="@+id/priceContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120$"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/oldPrice"
                android:layout_width="76dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/poppins_regular"
                android:letterSpacing="0"
                android:lineHeight="13sp"
                android:paintFlags="strike_thru_text|anti_alias"
                android:text="149$"
                android:textAllCaps="false"
                android:textColor="#5B5959"
                android:textSize="13sp" />

        </LinearLayout>

        <!--  Offers -->
        <LinearLayout
            android:id="@+id/offersContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/priceContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp">

            <!-- Orange header -->
            <TextView
                android:id="@+id/tvOffersHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Offers"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_orange_header_bg"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp"
                android:layout_marginTop="4dp" />

            <!-- White rounded list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="@drawable/rounded_white_bg"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="◁ Various Installment Options"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:paddingVertical="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="◁ Monthly Installment"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:paddingVertical="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="◁ Jumia Birthday"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!--  Add to Cart Bar -->
        <LinearLayout
            android:id="@+id/addToCartBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/offersContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:text="Add To Cart"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9900"
                android:textSize="16sp"
                android:textAllCaps="false" />

            <ImageView
                android:id="@+id/btnCall"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:background="@drawable/rounded_white_bg"
                android:elevation="2dp"
                android:src="@drawable/call" />

            <ImageView
                android:id="@+id/btnHome"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:background="@drawable/rounded_white_bg"
                android:elevation="2dp"
                android:src="@drawable/home_icon" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
